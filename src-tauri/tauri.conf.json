{
  "productName": "CuadernoDocente",
  "version": "0.1.0",
  "identifier": "com.imanol.lostale.cuaderno-docente",
  "build": {
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cuaderno Docente",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png","icons/128x128.png","icons/128x128@2x.png","icons/icon.icns","icons/icon.ico"],
    "targets": ["deb", "dmg", "msi", "nsis"]
  }
}
