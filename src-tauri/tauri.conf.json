{
  "productName": "CuadernoDocente",
  "version": "0.1.0",
  "identifier": "com.imanol.lostale.cuaderno-docente",
  "build": {
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist"
  },
